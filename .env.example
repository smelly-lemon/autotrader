# Coinbase Advanced Trade API — only needed for live trading.
# EITHER the new CDP key format:
COINBASE_API_KEY_ID=00000000-0000-0000-0000-000000000000
COINBASE_API_KEY_SECRET=base64-ed25519-secret==
# OR the legacy CDP format:
#COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/xxx
#COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"

# InfluxDB token for the (optional) hesiod tick-data source
INFLUX_TOKEN=
